import streamlit as st
import cv2
import numpy as np
from PIL import Image

st.set_page_config(page_title="Linda Sketch App", layout="centered")
st.title("🎨 محول الصور إلى رسم رصاص")

uploaded_file = st.file_uploader("اختر صورة...", type=["jpg", "png", "jpeg"])

if uploaded_file is not None:
    image = Image.open(uploaded_file)
    st.image(image, caption='الصورة الأصلية', use_column_width=True)
    
    if st.button('تحويل الآن'):
        img_array = np.array(image.convert('RGB'))
        gray_image = cv2.cvtColor(img_array, cv2.COLOR_RGB2GRAY)
        inverted_image = 255 - gray_image
        blurred_image = cv2.GaussianBlur(inverted_image, (21, 21), 0)
        inverted_blurred = 255 - blurred_image
        pencil_sketch = cv2.divide(gray_image, inverted_blurred, scale=256.0)
        st.image(pencil_sketch, caption='الرسم الناتج', use_column_width=True)
